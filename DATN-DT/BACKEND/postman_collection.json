{
  "info": {
    "name": "Soccer Booking API",
    "_postman_id": "soccer-booking-datn-2024",
    "description": "Backend API cho hệ thống quản lý sân bóng - DATN",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000", "type": "string" },
    { "key": "accessToken", "value": "", "type": "string" },
    { "key": "refreshToken", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Đăng ký",
          "event": [{ "listen": "test", "script": { "exec": ["const r = pm.response.json();", "if(r.success && r.data) {", "  pm.collectionVariables.set('accessToken', r.data.accessToken);", "  pm.collectionVariables.set('refreshToken', r.data.refreshToken);", "  console.log('Token saved!');", "}"], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Văn Đức\",\n  \"email\": \"duc@test.com\",\n  \"password\": \"123456\",\n  \"phone\": \"0912345678\",\n  \"role\": \"user\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api","auth","register"] }
          }
        },
        {
          "name": "Đăng nhập",
          "event": [{ "listen": "test", "script": { "exec": ["const r = pm.response.json();", "if(r.success && r.data) {", "  pm.collectionVariables.set('accessToken', r.data.accessToken);", "  pm.collectionVariables.set('refreshToken', r.data.refreshToken);", "  console.log('Token saved!');", "}"], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"duc@test.com\",\n  \"password\": \"123456\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api","auth","login"] }
          }
        },
        {
          "name": "Xem thông tin cá nhân (me)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/auth/me", "host": ["{{baseUrl}}"], "path": ["api","auth","me"] }
          }
        },
        {
          "name": "Đổi mật khẩu",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"currentPassword\": \"123456\",\n  \"newPassword\": \"newpass123\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/auth/change-password", "host": ["{{baseUrl}}"], "path": ["api","auth","change-password"] }
          }
        },
        {
          "name": "Làm mới token",
          "event": [{ "listen": "test", "script": { "exec": ["const r = pm.response.json();", "if(r.success && r.data) {", "  pm.collectionVariables.set('accessToken', r.data.accessToken);", "  pm.collectionVariables.set('refreshToken', r.data.refreshToken);", "}"], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/auth/refresh-token", "host": ["{{baseUrl}}"], "path": ["api","auth","refresh-token"] }
          }
        },
        {
          "name": "Quên mật khẩu (lấy OTP)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"duc@test.com\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/auth/forgot-password", "host": ["{{baseUrl}}"], "path": ["api","auth","forgot-password"] }
          }
        },
        {
          "name": "Reset mật khẩu bằng OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"duc@test.com\",\n  \"token\": \"NHAP_OTP_TU_CONSOLE\",\n  \"newPassword\": \"resetpass123\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/auth/reset-password", "host": ["{{baseUrl}}"], "path": ["api","auth","reset-password"] }
          }
        },
        {
          "name": "Đăng xuất",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/auth/logout", "host": ["{{baseUrl}}"], "path": ["api","auth","logout"] }
          }
        }
      ]
    },
    {
      "name": "👤 Users",
      "item": [
        {
          "name": "Xem profile (me)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/users/me", "host": ["{{baseUrl}}"], "path": ["api","users","me"] }
          }
        },
        {
          "name": "Cập nhật profile",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Tên mới\",\n  \"phone\": \"0987654321\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/users/me", "host": ["{{baseUrl}}"], "path": ["api","users","me"] }
          }
        },
        {
          "name": "[ADMIN] Danh sách users",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/users?page=1&limit=10", "host": ["{{baseUrl}}"], "path": ["api","users"], "query": [{"key":"page","value":"1"},{"key":"limit","value":"10"}] }
          }
        },
        {
          "name": "[ADMIN] Toggle trạng thái user",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/users/USER_ID/toggle-status", "host": ["{{baseUrl}}"], "path": ["api","users","USER_ID","toggle-status"] }
          }
        }
      ]
    },
    {
      "name": "⚽ Pitches (Sân bóng)",
      "item": [
        {
          "name": "Danh sách sân (public)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/pitches?page=1&limit=10", "host": ["{{baseUrl}}"], "path": ["api","pitches"], "query": [{"key":"page","value":"1"},{"key":"limit","value":"10"}] }
          }
        },
        {
          "name": "Lọc sân theo loại + giá",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/pitches?type=5-a-side&minPrice=100000&maxPrice=500000", "host": ["{{baseUrl}}"], "path": ["api","pitches"], "query": [{"key":"type","value":"5-a-side"},{"key":"minPrice","value":"100000"},{"key":"maxPrice","value":"500000"}] }
          }
        },
        {
          "name": "Chi tiết sân (public)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/pitches/PITCH_ID", "host": ["{{baseUrl}}"], "path": ["api","pitches","PITCH_ID"] }
          }
        },
        {
          "name": "[OWNER] Tạo sân mới",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Sân bóng ABC\",\n  \"address\": \"123 Nguyễn Văn A, Q.1\",\n  \"district\": \"Quận 1\",\n  \"city\": \"TP.HCM\",\n  \"type\": \"5-a-side\",\n  \"pricePerHour\": 200000,\n  \"openTime\": \"06:00\",\n  \"closeTime\": \"22:00\",\n  \"amenities\": [\"Đèn chiếu sáng\", \"Giữ xe\", \"Phòng thay đồ\"]\n}" },
            "url": { "raw": "{{baseUrl}}/api/pitches", "host": ["{{baseUrl}}"], "path": ["api","pitches"] }
          }
        },
        {
          "name": "[OWNER] Sân của tôi",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/pitches/my", "host": ["{{baseUrl}}"], "path": ["api","pitches","my"] }
          }
        },
        {
          "name": "[OWNER] Cập nhật sân",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"pricePerHour\": 250000,\n  \"status\": \"active\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/pitches/PITCH_ID", "host": ["{{baseUrl}}"], "path": ["api","pitches","PITCH_ID"] }
          }
        }
      ]
    },
    {
      "name": "📅 Bookings (Đặt sân)",
      "item": [
        {
          "name": "Xem lịch trống (public)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/bookings/available/PITCH_ID?date=2024-04-20", "host": ["{{baseUrl}}"], "path": ["api","bookings","available","PITCH_ID"], "query": [{"key":"date","value":"2024-04-20"}] }
          }
        },
        {
          "name": "Đặt sân",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"pitch\": \"PITCH_ID\",\n  \"date\": \"2024-04-20\",\n  \"startTime\": \"08:00\",\n  \"endTime\": \"10:00\",\n  \"note\": \"Đặt cho đội A\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/bookings", "host": ["{{baseUrl}}"], "path": ["api","bookings"] }
          }
        },
        {
          "name": "Lịch đặt của tôi",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/bookings/my", "host": ["{{baseUrl}}"], "path": ["api","bookings","my"] }
          }
        },
        {
          "name": "[OWNER/ADMIN] Tất cả bookings",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/bookings?page=1&limit=10", "host": ["{{baseUrl}}"], "path": ["api","bookings"], "query": [{"key":"page","value":"1"},{"key":"limit","value":"10"}] }
          }
        },
        {
          "name": "Hủy booking",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"cancelled\",\n  \"cancelReason\": \"Bận việc đột xuất\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/bookings/BOOKING_ID/status", "host": ["{{baseUrl}}"], "path": ["api","bookings","BOOKING_ID","status"] }
          }
        },
        {
          "name": "[OWNER] Xác nhận booking",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"confirmed\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/bookings/BOOKING_ID/status", "host": ["{{baseUrl}}"], "path": ["api","bookings","BOOKING_ID","status"] }
          }
        }
      ]
    },
    {
      "name": "⭐ Reviews (Đánh giá)",
      "item": [
        {
          "name": "Xem đánh giá sân (public)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/reviews/PITCH_ID", "host": ["{{baseUrl}}"], "path": ["api","reviews","PITCH_ID"] }
          }
        },
        {
          "name": "Đánh giá sân",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"rating\": 5,\n  \"comment\": \"Sân rất đẹp, phục vụ tốt!\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/reviews/PITCH_ID", "host": ["{{baseUrl}}"], "path": ["api","reviews","PITCH_ID"] }
          }
        },
        {
          "name": "Xóa đánh giá",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/reviews/REVIEW_ID", "host": ["{{baseUrl}}"], "path": ["api","reviews","REVIEW_ID"] }
          }
        }
      ]
    },
    {
      "name": "🟢 Health Check",
      "item": [
        {
          "name": "Server health",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/health", "host": ["{{baseUrl}}"], "path": ["api","health"] }
          }
        }
      ]
    }
  ]
}
